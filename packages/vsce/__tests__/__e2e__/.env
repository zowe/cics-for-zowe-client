# ----------------------------------------------
# Variables for CICS Explorer end-to-end testing
# ----------------------------------------------

# Path to the CICS home folder where configurations are stored (relative to current directory)
CICS_TEST_DIR=".CICS"

# VS Code version to run tests with - can be "stable", "insiders", or a specific version e.g. "1.80.0"
CICS_TEST_VSCODE_VER="1.93.1"