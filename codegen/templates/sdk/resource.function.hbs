import { type AbstractSession, ImperativeError, ImperativeExpect, Logger } from "@zowe/imperative";
import { CicsCmciConstants } from "../constants";
import type { ICMCIApiResponse, {{parmsInterface}} } from "../doc";
import { performAction } from "../utils/ResourceActions";

/**
 * {{capitalize actionVerb}} a {{humanNameLower}} in CICS
 * @param {AbstractSession} session - the session to connect to CMCI with
 * @param { {{parmsInterface}} } parms - parameters for {{actionVerb}} the {{humanNameLower}}
{{#each positionals}}
 * @param {string} parms.{{sdkParamName}} - {{description}}{{#if ../maxNameLength}} (1-{{../maxNameLength}} characters){{/if}}
{{/each}}
{{#each options}}
 * @param {string} [parms.{{sdkParamName}}] - {{description}}
{{/each}}
 * @returns {Promise<ICMCIApiResponse>} promise that resolves to the response
{{#each positionals}}
 * @throws {ImperativeError} CICS {{../humanName}} name not defined{{#if ../maxNameLength}}, blank, or exceeds maximum length{{else}} or blank{{/if}}
{{/each}}
{{#if hasRegionName}}
 * @throws {ImperativeError} CICS region name not defined or blank
{{/if}}
{{#if hasValidation}}
 * @throws {ImperativeError} Invalid parameter value
{{/if}}
 * @throws {ImperativeError} CicsCmciRestClient request fails
 */
export async function {{sdkFunction}}(session: AbstractSession, parms: {{parmsInterface}}): Promise<ICMCIApiResponse> {
  // Validate required parameters
{{#each positionals}}
  ImperativeExpect.toBeDefinedAndNonBlank(parms.{{sdkParamName}}, "CICS {{../humanName}} name", "CICS {{../humanNameLower}} name is required");
{{/each}}
{{#if hasRegionName}}
  ImperativeExpect.toBeDefinedAndNonBlank(parms.regionName, "CICS Region name", "CICS region name is required");
{{/if}}

{{#if maxNameLength}}
  // Validate {{humanNameLower}} name length (CICS resource names are limited to {{maxNameLength}} characters)
  const maxLength = CicsCmciConstants.{{maxLengthConstant}};
  if (parms.name.length > maxLength) {
    throw new ImperativeError({
      msg: `CICS {{humanNameLower}} name "${parms.name}" exceeds maximum length of ${maxLength} characters`,
    });
  }

{{/if}}
  Logger.getAppLogger().debug(
    `Attempting to {{actionLower}} a {{humanNameLower}} with the following parameters:\n%s`,
    JSON.stringify(parms)
  );

{{#if parameters}}
{{#each parameters}}
  // Get {{name}} parameter value
  const {{camelCase name}}Value = parms.{{sdkParamField}} ? parms.{{sdkParamField}}.trim(){{#if transform}}.{{transform}}(){{/if}} : "{{defaultValue}}";

{{#if validation}}
  // Validate {{name}} parameter
  const paramValue = {{camelCase name}}Value;
  if (!CicsCmciConstants.{{validation}}.includes(paramValue)) {
    const allowedValuesStr = CicsCmciConstants.{{validation}}.join(", ");
    throw new ImperativeError({
      msg: `Invalid {{name}} parameter value: "${paramValue}". Must be one of: ${allowedValuesStr}`,
    });
  }

{{/if}}
{{/each}}
{{/if}}
  // Use generic performAction utility
  return performAction(
    session,
    CicsCmciConstants.{{sdkResourceType}},
    "{{actionName}}",
    {
      name: parms.name,
      regionName: parms.regionName,
      cicsPlex: parms.cicsPlex,
    },
    CicsCmciConstants.{{criteriaFieldConstant}}{{#if parameters}},
{{#if (eq parameters.length 1)}}
    { name: "{{parameters.[0].name}}", value: {{camelCase parameters.[0].name}}Value }
{{else}}
    [
{{#each parameters}}
      { name: "{{name}}", value: {{camelCase name}}Value },
{{/each}}
    ]
{{/if}}{{/if}}
  );
}