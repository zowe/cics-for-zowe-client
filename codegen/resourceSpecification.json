    },
    "PIPELINENAME": {
      "name": "pipelineName",
      "type": "string",
      "description": "Pipeline that will process the request (pipeline URIMaps only, up to 8 characters)."
    },
    "CERTIFICATE": {
      "name": "certificate",
      "type": "string",
      "description": "Certificate that will be used to negotiate an SSL handshake (client URIMaps only)."
    },
    "AUTHENTICATE": {
      "name": "authenticate",
      "type": "string",
      "description": "Authentication and identification scheme to be used for URIMAPs (client URIMaps only, NO or BASIC)."
    },
    "DESCRIPTION": {
      "name": "description",
      "type": "string",
      "description": "Description text for the resource."
    },
    "TRANSACTIONNAME": {
      "name": "transactionName",
      "type": "string",
      "description": "Transaction resource associated with the URIMap (pipeline URIMaps only, up to 4 characters)."
    },
    "WEBSERVICENAME": {
      "name": "webserviceName",
      "type": "string",
      "description": "Web service resource associated with the URIMap (pipeline URIMaps only, up to 32 characters)."
    },
    "ENABLEATTR": {
      "name": "enable",
      "type": "boolean",
      "description": "Enable attribute of the resource."
    },
    "TCPIPSERVICE": {
      "name": "tcpipservice",
      "type": "string",
      "description": "The TCPIPSERVICE to which a URIMAP applies (server and pipeline URIMAPs only, up to 8 characters)."
    }
