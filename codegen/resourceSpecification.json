      "name": "path",
      "type": "string",
      "description": "Path component of URI to which the map applies (up to 255 characters)."
    },
    "HOST": {
      "name": "host",
      "type": "string",
      "description": "Host component of URI to which the map applies (up to 116 characters)."
    },
    "SCHEME": {
      "name": "scheme",
      "type": "string",
      "description": "Scheme component of URI to which the map applies (http or https)."
    },
    "PROGRAMNAME": {
      "name": "programName",
      "type": "string",
