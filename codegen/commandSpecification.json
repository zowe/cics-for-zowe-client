{
  "$schema": "./commandSpecification.schema.json",
  "commands": [
    {
      "group": "open",
      "groupAliases": ["opn"],
      "groupSummary": "Open resources in CICS",
      "groupDescription": "Open resources (for example, local files) in CICS through IBM CMCI.",
      "resources": [
        {
          "name": "CICSLocalFile",
          "aliases": ["lf"],
          "humanName": "Local File",
          "humanNameLower": "local file",
          "sdkResourceType": "CICS_CMCI_LOCAL_FILE",
          "parmsInterface": "ILocalFileParms",
          "criteriaField": "file",
          "maxNameLength": 8,
          "actions": [
            {
              "name": "OPEN",
              "actionLower": "open",
              "actionVerb": "opening",
              "actionPastTense": "opened",
              "sdkFunction": "openLocalFile",
              "cliHandler": "LocalFileHandler",
              "vsceCommandId": "cics-extension-for-zowe.openLocalFile",
              "positionals": [
                {
                  "name": "fileName",
                  "description": "The name of the local file to open. The maximum length of the file name is eight characters.",
                  "type": "string",
                  "required": true,
                  "sdkParamName": "name"
                }
              ],
              "options": [
                {
                  "name": "region-name",
                  "description": "The CICS region name in which to open the local file",
                  "type": "string",
                  "sdkParamName": "regionName"
                },
                {
                  "name": "cics-plex",
                  "description": "The name of the CICSPlex in which to open the local file",
                  "type": "string",
                  "sdkParamName": "cicsPlex"
                }
              ],
              "parameters": [],
              "messages": {
                "success": "The local file '%s' was opened successfully.",
                "progress": "Opening local file in CICS"
              },
              "examples": [
                {
                  "description": "Open a local file named TESTFILE in the region named MYREGION",
                  "options": "TESTFILE --region-name MYREGION"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "group": "close",
      "groupAliases": ["cls"],
      "groupSummary": "Close resources in CICS",
      "groupDescription": "Close resources (for example, local files) in CICS through IBM CMCI.",
      "resources": [
        {
          "name": "CICSLocalFile",
          "aliases": ["lf"],
          "humanName": "Local File",
          "humanNameLower": "local file",
          "sdkResourceType": "CICS_CMCI_LOCAL_FILE",
          "parmsInterface": "ILocalFileParms",
          "criteriaField": "file",
          "maxNameLength": 8,
          "actions": [
            {
              "name": "CLOSE",
              "actionLower": "close",
              "actionVerb": "closing",
              "actionPastTense": "closed",
              "sdkFunction": "closeLocalFile",
              "cliHandler": "LocalFileHandler",
              "vsceCommandId": "cics-extension-for-zowe.closeLocalFile",
              "positionals": [
                {
                  "name": "fileName",
                  "description": "The name of the local file to close. The maximum length of the file name is eight characters.",
                  "type": "string",
                  "required": true,
                  "sdkParamName": "name"
                }
              ],
              "options": [
                {
                  "name": "region-name",
                  "description": "The CICS region name in which to close the local file",
                  "type": "string",
                  "sdkParamName": "regionName"
                },
                {
                  "name": "cics-plex",
                  "description": "The name of the CICSPlex in which to close the local file",
                  "type": "string",
                  "sdkParamName": "cicsPlex"
                },
                {
                  "name": "busy",
                  "description": "The busy condition option for closing the file. Valid values: WAIT, NOWAIT, FORCE. Default is WAIT.",
                  "type": "string",
                  "defaultValue": "WAIT",
                  "allowableValues": ["WAIT", "NOWAIT", "FORCE"],
                  "caseSensitive": false,
                  "sdkParamName": "busy",
                  "constantReference": "CICS_LOCAL_FILE_BUSY_VALUES"
                }
              ],
              "parameters": [
                {
                  "name": "BUSY",
                  "sdkParamField": "busy",
                  "transform": "toUpperCase",
                  "defaultValue": "WAIT",
                  "validation": "CICS_LOCAL_FILE_BUSY_VALUES"
                }
              ],
              "vsceParameter": {
                "name": "busy",
                "prompt": "Choose one of the following for the file busy condition",
                "choices": {
                  "Wait": "WAIT",
                  "No Wait": "NOWAIT",
                  "Force": "FORCE"
                }
              },
              "messages": {
                "success": "The local file '%s' was closed successfully.",
                "progress": "Closing local file from CICS"
              },
              "examples": [
                {
                  "description": "Close a local file named TESTFILE from the region named MYREGION",
                  "options": "TESTFILE --region-name MYREGION"
                },
                {
                  "description": "Close a local file named TESTFILE from the region named MYREGION with BUSY=FORCE",
                  "options": "TESTFILE --region-name MYREGION --busy FORCE"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "group": "enable",
      "groupAliases": ["enb"],
      "groupSummary": "Enable resources in CICS",
      "groupDescription": "Enable resources (for example, local files) in CICS through IBM CMCI.",
      "resources": [
        {
          "name": "CICSLocalFile",
          "aliases": ["lf"],
          "humanName": "Local File",
          "humanNameLower": "local file",
          "sdkResourceType": "CICS_CMCI_LOCAL_FILE",
          "parmsInterface": "ILocalFileParms",
          "criteriaField": "file",
          "maxNameLength": 8,
          "actions": [
            {
              "name": "ENABLE",
              "actionLower": "enable",
              "actionVerb": "enabling",
              "actionPastTense": "enabled",
              "sdkFunction": "enableLocalFile",
              "cliHandler": "LocalFileHandler",
              "vsceCommandId": "cics-extension-for-zowe.enableLocalFile",
              "positionals": [
                {
                  "name": "fileName",
                  "description": "The name of the local file to enable. The maximum length of the file name is eight characters.",
                  "type": "string",
                  "required": true,
                  "sdkParamName": "name"
                }
              ],
              "options": [
                {
                  "name": "region-name",
                  "description": "The CICS region name in which to enable the local file",
                  "type": "string",
                  "sdkParamName": "regionName"
                },
                {
                  "name": "cics-plex",
                  "description": "The name of the CICSPlex in which to enable the local file",
                  "type": "string",
                  "sdkParamName": "cicsPlex"
                }
              ],
              "parameters": [],
              "messages": {
                "success": "The local file '%s' was enabled successfully.",
                "progress": "Enabling local file in CICS"
              },
              "examples": [
                {
                  "description": "Enable a local file named TESTFILE in the region named MYREGION",
                  "options": "TESTFILE --region-name MYREGION"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}